{%- style -%}
  .bbt-wa-cta {
    display: block;
    background: var(--bbt-wa);
    text-decoration: none;
    padding: 1.6rem 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .bbt-wa-cta {
      padding: 1.8rem 4rem;
    }
  }

  .bbt-wa-cta__row {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .bbt-wa-cta__icon {
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
  }

  .bbt-wa-cta__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bbt-wa-cta__icon-cutout {
    fill: var(--bbt-wa);
  }

  .bbt-wa-cta__text {
    flex: 1 1 auto;
  }

  .bbt-wa-cta__title {
    color: #ffffff;
    font-size: 1.7rem;
    font-weight: 700;
    margin: 0;
  }

  .bbt-wa-cta__subtitle {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.3rem;
    margin: 0.2rem 0 0;
  }

  .bbt-wa-cta__arrow {
    flex: 0 0 auto;
    color: #ffffff;
    font-size: 2.4rem;
    line-height: 1;
  }
{%- endstyle -%}

<a
  href="{{ section.settings.whatsapp_link }}"
  class="bbt-wa-cta"
  target="_blank"
  rel="noopener"
  aria-label="{{ section.settings.title }}"
>
  <div class="bbt-wa-cta__row">
    <span class="bbt-wa-cta__icon" aria-hidden="true">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M16.001 3C9.096 3 3.5 8.596 3.5 15.5c0 2.31.63 4.474 1.727 6.33L3 29l7.359-2.19a12.44 12.44 0 0 0 5.642 1.357h.005c6.905 0 12.5-5.596 12.5-12.5S22.906 3 16.001 3Zm0 22.688h-.004a10.15 10.15 0 0 1-5.174-1.418l-.371-.22-3.844 1.144 1.163-3.75-.242-.385a10.15 10.15 0 0 1-1.555-5.559c0-5.618 4.573-10.19 10.194-10.19 2.723 0 5.28 1.06 7.204 2.985a10.12 10.12 0 0 1 2.984 7.207c0 5.618-4.573 10.186-10.19 10.186h-.165Z"
          fill="#fff"
        />
        <path
          class="bbt-wa-cta__icon-cutout"
          d="M12.784 10.688c-.24-.534-.494-.545-.722-.554-.187-.008-.401-.007-.615-.007-.214 0-.561.08-.855.401-.294.32-1.121 1.096-1.121 2.674 0 1.578 1.148 3.103 1.308 3.317.16.213 2.216 3.553 5.472 4.838 2.706 1.068 3.258.856 3.846.803.588-.053 1.897-.775 2.165-1.524.267-.749.267-1.39.187-1.524-.08-.133-.293-.213-.614-.374-.32-.16-1.898-.936-2.192-1.043-.294-.107-.508-.16-.722.16-.213.32-.828 1.043-1.015 1.257-.187.213-.374.24-.694.08-.32-.16-1.352-.499-2.575-1.588-.952-.849-1.595-1.897-1.782-2.217-.187-.32-.02-.493.14-.653.144-.144.32-.374.481-.56.16-.187.213-.32.32-.534.107-.213.053-.4-.027-.56-.08-.16-.694-1.744-.985-2.392Z"
        />
      </svg>
    </span>
    <span class="bbt-wa-cta__text">
      <span class="bbt-wa-cta__title">{{ section.settings.title }}</span>
      <span class="bbt-wa-cta__subtitle">{{ section.settings.subtitle }}</span>
    </span>
    <span class="bbt-wa-cta__arrow" aria-hidden="true">›</span>
  </div>
</a>

{% schema %}
{
  "name": "BBT WhatsApp CTA",
  "tag": "section",
  "class": "section-bbt-whatsapp-cta",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Chat to order on WhatsApp"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "063 500 1740 · Reply in minutes"
    },
    {
      "type": "text",
      "id": "whatsapp_link",
      "label": "WhatsApp link",
      "default": "https://wa.me/27635001740"
    }
  ],
  "presets": [
    {
      "name": "BBT WhatsApp CTA"
    }
  ]
}
{% endschema %}
