{%- style -%}
  .bbt-page-faq {
    background: var(--bbt-black);
    padding: 3rem 0 4rem;
  }

  .bbt-page-faq__list {
    max-width: 68rem;
    margin: 0 auto;
  }

  .bbt-page-faq__item {
    border-bottom: var(--bbt-border);
  }

  .bbt-page-faq__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.6rem 0.4rem;
    color: var(--bbt-gold);
    font-weight: 700;
    font-size: 1.6rem;
    cursor: pointer;
    list-style: none;
  }

  .bbt-page-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .bbt-page-faq__item summary::after {
    content: '+';
    color: var(--bbt-gold);
    font-size: 2rem;
    flex-shrink: 0;
  }

  .bbt-page-faq__item[open] summary::after {
    content: '\2212';
  }

  .bbt-page-faq__answer {
    color: var(--bbt-cream);
    font-size: 1.5rem;
    line-height: 1.6;
    padding: 0 0.4rem 1.8rem;
  }

  .bbt-page-faq__wa-strip {
    display: block;
    margin: 3rem auto 0;
    max-width: 68rem;
    text-align: center;
    padding: 1.4rem 1.5rem;
    background: var(--bbt-wa);
    color: #ffffff;
    font-weight: 700;
    border-radius: var(--bbt-radius);
    text-decoration: none;
  }
{%- endstyle -%}

<div class="bbt-page-faq page-width">
  <div class="bbt-page-faq__list">
    {%- for block in section.blocks -%}
      {%- if block.type == 'question' -%}
        <details class="bbt-page-faq__item" {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="bbt-page-faq__answer rte">{{ block.settings.answer }}</div>
        </details>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <a href="https://wa.me/27635001740" class="bbt-page-faq__wa-strip" target="_blank" rel="noopener">
    WhatsApp us on 063 500 1740 — we reply in minutes
  </a>
</div>

{% schema %}
{
  "name": "BBT FAQ",
  "tag": "section",
  "class": "section-bbt-page-faq",
  "settings": [],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Answer</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BBT FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "How do I order online?",
            "answer": "<p>Browse our products, add to cart and checkout securely via Peach Payments. For large orders or fitment queries, WhatsApp us on 063 500 1740.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Can I collect in store?",
            "answer": "<p>Yes — click & collect is free from 140 Modderfontein Road, Tembisa. Select \"Pickup\" at checkout.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you offer same-day fitment?",
            "answer": "<p>Yes. WhatsApp us on 063 500 1740 to confirm availability and book your fitment slot.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "What is your battery warranty?",
            "answer": "<p>Osaka batteries carry a 6-month pro-rata warranty. Exide Eco batteries carry a 12-month pro-rata warranty. If your battery fails within the warranty period, bring it in — we calculate a fair refund based on months of actual use.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How does the trade-in credit work?",
            "answer": "<p>When you buy a battery and bring your old one at collection, we credit you R250 (Osaka) or R475 (Exide) at the counter.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you ship nationwide?",
            "answer": "<p>Yes — we deliver nationwide across South Africa.<br>Batteries: R100 flat fee anywhere in SA.<br>Tyres: R100 per tyre nationwide.<br>Combos: R600 flat fee via Pudo nationwide.<br>Accessories & Oils: R100 flat fee on all orders.<br>Free click & collect available at our Tembisa store.<br>WhatsApp us on 063 500 1740 for delivery queries.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "What payment methods do you accept?",
            "answer": "<p>All major credit and debit cards via Peach Payments, EFT via Pay by Bank, Payflex buy-now-pay-later, and Scan to Pay. Cash on collection also accepted.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
