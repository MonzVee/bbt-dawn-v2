{%- style -%}
  .bbt-footer {
    background: var(--bbt-black);
    border-top: 1px solid var(--bbt-surface);
    padding: 3.5rem 1.5rem 2rem;
  }

  @media screen and (min-width: 750px) {
    .bbt-footer {
      padding: 4.5rem 4rem 2.5rem;
    }
  }

  .bbt-footer__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .bbt-footer__top {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--bbt-surface);
  }

  @media screen and (min-width: 750px) {
    .bbt-footer__top {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .bbt-footer__brand-logo {
    display: block;
    color: var(--bbt-gold);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 0.6rem;
  }

  .bbt-footer__tagline {
    color: var(--bbt-muted);
    font-size: 1.4rem;
    margin: 0;
    max-width: 320px;
  }

  .bbt-footer__columns {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .bbt-footer__column-title {
    color: #ffffff;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 1.2rem;
  }

  .bbt-footer__column-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .bbt-footer__column-list a {
    color: var(--bbt-cream);
    font-size: 1.4rem;
    text-decoration: none;
  }

  .bbt-footer__column-list a:hover {
    color: var(--bbt-gold);
  }

  .bbt-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    padding-top: 2rem;
  }

  @media screen and (min-width: 750px) {
    .bbt-footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .bbt-footer__social {
    display: flex;
    gap: 1rem;
  }

  .bbt-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bbt-dark);
    border: 1px solid var(--bbt-surface);
    color: var(--bbt-cream);
  }

  .bbt-footer__social a:hover {
    border-color: var(--bbt-gold);
    color: var(--bbt-gold);
  }

  .bbt-footer__social svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .bbt-footer__payments {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .bbt-footer__payment-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--bbt-surface);
    border-radius: var(--bbt-radius-sm);
    color: var(--bbt-muted);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .bbt-footer__copyright {
    color: var(--bbt-muted);
    font-size: 1.2rem;
    margin: 0;
  }
{%- endstyle -%}

<div class="bbt-footer">
  <div class="bbt-footer__inner">
    <div class="bbt-footer__top">
      <div>
        <span class="bbt-footer__brand-logo">{{ section.settings.logo_text }}</span>
        <p class="bbt-footer__tagline">{{ section.settings.tagline }}</p>
      </div>

      <div class="bbt-footer__columns">
        <div>
          <p class="bbt-footer__column-title">{{ section.settings.shop_column_title }}</p>
          <ul class="bbt-footer__column-list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'shop_link' -%}
                <li {{ block.shopify_attributes }}><a href="{{ block.settings.link }}">{{ block.settings.label }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        <div>
          <p class="bbt-footer__column-title">{{ section.settings.company_column_title }}</p>
          <ul class="bbt-footer__column-list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'company_link' -%}
                <li {{ block.shopify_attributes }}><a href="{{ block.settings.link }}">{{ block.settings.label }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>

    <div class="bbt-footer__bottom">
      <div class="bbt-footer__social">
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.89h2.78l-.44 2.91h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94Z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2c2.72 0 3.06.01 4.12.06 1.06.05 1.79.22 2.43.47.66.26 1.22.6 1.77 1.15.55.55.9 1.11 1.15 1.77.25.64.42 1.37.47 2.43.05 1.06.06 1.4.06 4.12s-.01 3.06-.06 4.12c-.05 1.06-.22 1.79-.47 2.43a4.9 4.9 0 0 1-1.15 1.77 4.9 4.9 0 0 1-1.77 1.15c-.64.25-1.37.42-2.43.47-1.06.05-1.4.06-4.12.06s-3.06-.01-4.12-.06c-1.06-.05-1.79-.22-2.43-.47a4.9 4.9 0 0 1-1.77-1.15 4.9 4.9 0 0 1-1.15-1.77c-.25-.64-.42-1.37-.47-2.43C2.01 15.06 2 14.72 2 12s.01-3.06.06-4.12c.05-1.06.22-1.79.47-2.43.26-.66.6-1.22 1.15-1.77A4.9 4.9 0 0 1 5.45.53c.64-.25 1.37-.42 2.43-.47C8.94.01 9.28 0 12 0Zm0 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0 8.2a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4Zm5.2-8.4a1.17 1.17 0 1 1-2.34 0 1.17 1.17 0 0 1 2.34 0Z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16.6 5.82a4.28 4.28 0 0 1-2.63-2.55h-3.06v13.44a2.6 2.6 0 1 1-1.83-2.48v-3.1a5.6 5.6 0 1 0 4.89 5.58V9.9a7.25 7.25 0 0 0 4.24 1.36V8.2a4.28 4.28 0 0 1-1.61-2.38Z"/></svg>
          </a>
        {%- endif -%}
      </div>

      <div class="bbt-footer__payments">
        {%- for block in section.blocks -%}
          {%- if block.type == 'payment_badge' -%}
            <span class="bbt-footer__payment-badge" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <p class="bbt-footer__copyright">{{ section.settings.copyright_text }}</p>
  </div>
</div>

{% schema %}
{
  "name": "BBT Footer",
  "tag": "section",
  "class": "section-bbt-footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "BETTER BATTERY TYRES"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Tembisa & Midrand fitment centre"
    },
    {
      "type": "text",
      "id": "shop_column_title",
      "label": "Shop column title",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "company_column_title",
      "label": "Company column title",
      "default": "Company"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2026 Better Battery Tyres · betterbattery.co.za"
    }
  ],
  "blocks": [
    {
      "type": "shop_link",
      "name": "Shop link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "company_link",
      "name": "Company link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "payment_badge",
      "name": "Payment badge",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BBT Footer",
      "blocks": [
        { "type": "shop_link", "settings": { "label": "Taxi & Minibus", "link": "/collections/taxi-minibus" } },
        { "type": "shop_link", "settings": { "label": "7-Seater", "link": "/collections/7-seater" } },
        { "type": "shop_link", "settings": { "label": "Passenger Cars", "link": "/collections/passenger-cars" } },
        { "type": "shop_link", "settings": { "label": "Car Accessories", "link": "/collections/car-accessories" } },
        { "type": "shop_link", "settings": { "label": "Oils & Fluids", "link": "/collections/oils-fluids" } },
        { "type": "shop_link", "settings": { "label": "All Products", "link": "/collections/all" } },
        { "type": "company_link", "settings": { "label": "About Us", "link": "/pages/about" } },
        { "type": "company_link", "settings": { "label": "Contact", "link": "/pages/contact" } },
        { "type": "company_link", "settings": { "label": "Reviews", "link": "/pages/reviews" } },
        { "type": "company_link", "settings": { "label": "Workshop Trade", "link": "/pages/workshop-trade" } },
        { "type": "company_link", "settings": { "label": "WhatsApp Us", "link": "https://wa.me/27635001740" } },
        { "type": "payment_badge", "settings": { "label": "VISA" } },
        { "type": "payment_badge", "settings": { "label": "MC" } },
        { "type": "payment_badge", "settings": { "label": "Peach Payments" } }
