{%- style -%}
  .bbt-reviews {
    background: var(--bbt-black);
    padding: 3.5rem 0;
  }

  .bbt-reviews__header {
    text-align: center;
    margin: 0 1.5rem 2rem;
  }

  .bbt-reviews__title {
    color: #ffffff;
    font-size: 2.6rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .bbt-reviews__rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .bbt-reviews__stars {
    color: var(--bbt-gold);
    font-size: 1.8rem;
    letter-spacing: 0.1em;
  }

  .bbt-reviews__count {
    color: var(--bbt-cream);
    font-size: 1.4rem;
    font-weight: 600;
  }

  .bbt-reviews__rail {
    display: flex;
    gap: 1.2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0 1.5rem 1rem;
    -webkit-overflow-scrolling: touch;
  }

  @media screen and (min-width: 750px) {
    .bbt-reviews__rail {
      padding: 0 4rem 1rem;
    }
  }

  .bbt-reviews__card {
    flex: 0 0 auto;
    width: 300px;
    scroll-snap-align: start;
    background: var(--bbt-dark);
    border: 1px solid #2a2a2a;
    border-radius: var(--bbt-radius);
    padding: 1.8rem;
  }

  .bbt-reviews__card-stars {
    color: var(--bbt-gold);
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
  }

  .bbt-reviews__card-quote {
    color: var(--bbt-cream);
    font-size: 1.4rem;
    line-height: 1.5;
    margin: 0 0 1.5rem;
  }

  .bbt-reviews__card-reviewer {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .bbt-reviews__avatar {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bbt-surface);
    color: var(--bbt-gold);
    font-weight: 700;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bbt-reviews__reviewer-name {
    color: #ffffff;
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0;
  }

  .bbt-reviews__reviewer-meta {
    color: var(--bbt-muted);
    font-size: 1.15rem;
    margin: 0;
  }

  .bbt-reviews__footer {
    text-align: center;
    margin-top: 2rem;
  }

  .bbt-reviews__footer a {
    color: var(--bbt-gold);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
  }

  .bbt-reviews__footer a:hover {
    text-decoration: underline;
  }
{%- endstyle -%}

<div class="bbt-reviews">
  <div class="bbt-reviews__header">
    <h2 class="bbt-reviews__title">{{ section.settings.title }}</h2>
    <div class="bbt-reviews__rating">
      <span class="bbt-reviews__stars" aria-hidden="true">★★★★★</span>
      <span class="bbt-reviews__count">{{ section.settings.rating_count_text }}</span>
    </div>
  </div>

  <div class="bbt-reviews__rail">
    {%- for block in section.blocks -%}
      <div class="bbt-reviews__card" {{ block.shopify_attributes }}>
        <p class="bbt-reviews__card-stars" aria-hidden="true">★★★★★</p>
        <p class="bbt-reviews__card-quote">"{{ block.settings.quote }}"</p>
        <div class="bbt-reviews__card-reviewer">
          <span class="bbt-reviews__avatar" aria-hidden="true">{{ block.settings.reviewer_name | slice: 0, 1 }}</span>
          <div>
            <p class="bbt-reviews__reviewer-name">{{ block.settings.reviewer_name }}</p>
            <p class="bbt-reviews__reviewer-meta">{{ block.settings.reviewer_meta }}</p>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.footer_link != blank -%}
    <div class="bbt-reviews__footer">
      <a href="{{ section.settings.footer_link }}" target="_blank" rel="noopener">
        {{ section.settings.footer_label }} →
      </a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "BBT Reviews",
  "tag": "section",
  "class": "section-bbt-reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What Customers Say"
    },
    {
      "type": "text",
      "id": "rating_count_text",
      "label": "Rating label text",
      "info": "No review count — Google review count is not displayed on-site",
      "default": "Google Reviews"
    },
    {
      "type": "text",
      "id": "footer_label",
      "label": "Footer link label",
      "default": "Read all reviews on Google"
    },
    {
      "type": "text",
      "id": "footer_link",
      "label": "Footer link",
      "default": "https://g.page/r/CURQ3dL5N-RjEBM/review"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name"
        },
        {
          "type": "text",
          "id": "reviewer_meta",
          "label": "Reviewer meta",
          "default": "Google Review · Verified Customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BBT Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "quote": "Got my Quantum combo fitted here — rims look amazing. Fast service, in and out in under an hour. Will definitely be back!",
            "reviewer_name": "Thabo M.",
            "reviewer_meta": "Google Review · Verified Customer"
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "Best prices on batteries in Tembisa. Brought my old battery, got my discount at the counter. Honest and fast. Highly recommended.",
            "reviewer_name": "Nomsa K.",
            "reviewer_meta": "Google Review · Verified Customer"
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "Bought tyres and rims combo. Price was right, fitment was quick. Staff were helpful and professional. Will send all my drivers here.",
            "reviewer_name": "Sipho D.",
            "reviewer_meta": "Google Review · Verified Customer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
